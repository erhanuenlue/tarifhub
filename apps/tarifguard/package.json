    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "^15.5.19",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.10",
    "tailwindcss": "3.4.6",
    "typescript": "5.5.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
