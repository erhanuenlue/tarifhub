# Copy to .env (git-ignored, read-denied to Claude). Pipeline runs without ANTHROPIC_API_KEY
# (deterministic ai_map fallback) — tests rely on that.
TARIFHUB_DB_URL=postgresql://tarifhub:tarifhub@localhost:5432/tarifhub
TARIFHUB_REVIEW_THRESHOLD=0.85
ANTHROPIC_API_KEY=

# Optional: absolute path to your Obsidian vault. If set, the brain_sync hook mirrors
# vault/ + docs/adr/ + LEARNINGS.md into "<OBSIDIAN_VAULT>/tarifhub/" at every session end.
# Leave empty if you open the repo itself in Obsidian (recommended).
OBSIDIAN_VAULT=
