# Copy to .env and adjust. The ingestion test suite needs NONE of these — it runs
# fully offline on SQLite with no LLM. These are for local Postgres / live runs.

# --- Ingestion service (Python) ---
# SQLite (default, offline) or Postgres, e.g.
#   postgresql://tarifhub:tarifhub@localhost:5432/tarifhub
TARIFHUB_DB_URL=sqlite:///./tarifhub_dev.db
# Confidence below this threshold flags a record for human review.
TARIFHUB_REVIEW_THRESHOLD=0.85
# Embeddings backend: "stub" (offline, default) or "e5" (needs the optional 'ai' extra).
TARIFHUB_EMBEDDINGS=stub
# Override the bundled sample directory (optional).
# TARIFHUB_SAMPLE_DIR=
# Presence of this key is the ONLY switch that enables the live Claude harmonizer
# (pre-freeze, non-billing fields). Leave empty for deterministic rules only.
ANTHROPIC_API_KEY=

# --- Serving service (Quarkus) ---
QUARKUS_DATASOURCE_USERNAME=tarifhub
QUARKUS_DATASOURCE_PASSWORD=tarifhub
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://localhost:5432/tarifhub
# Only the serving.search package uses this (semantic search over frozen records).
QUARKUS_LANGCHAIN4J_ANTHROPIC_API_KEY=

# --- Object storage (raw source artifacts) ---
MINIO_ROOT_USER=tarifhub
MINIO_ROOT_PASSWORD=tarifhub-dev-secret
